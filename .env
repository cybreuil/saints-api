# PostgreSQL connection string
DATABASE_URL=postgres://rip@localhost:5432/saints_db

#BIND ADDRESS
# 0.0.0.0 toi allow all connection
# 127.0.0.1 only for locals / might be better
BIND_ADDRESS=127.0.0.1

# Port for the HTTP server (default: 8080)
API_PORT=8080

# Secret key for JWT signing (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret

# Log level: error | warn | info | debug | trace
RUST_LOG=info
